<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SLIIT Library Management System</title>
    <link rel="stylesheet" href="css/index.css">
</head>
<body>

<header class="main-header">
    <div class="container header-content">
        <div class="brand">
            <div class="logo-box">SL</div>
            <div>
                <h1>SLIIT Library</h1>
                <p>Library Management System</p>
            </div>
        </div>

        <nav class="main-nav">
            <a href="index.jsp">Home</a>
            <a href="login.jsp" class="nav-login">Login</a>
            <a href="register.jsp" class="nav-register">Register</a>
        </nav>
    </div>
</header>

<section class="library-hero">
    <div class="container hero-grid">
        <div class="hero-text">
            <span class="hero-badge">Online Access</span>
            <h2>Search and manage your library account in minutes.</h2>
            <p>
                Use your SLIIT account to register, log in, and keep track of
                borrowed books and due dates from one place.
            </p>
            <div class="hero-actions">
                <a href="register.jsp" class="primary-btn">Create Account</a>
                <a href="login.jsp" class="secondary-btn">Login</a>
            </div>
        </div>

        <div class="hero-panel">
            <h3>Library Hours</h3>
            <p><strong>Monday - Friday:</strong> 8.00 AM - 6.00 PM</p>
            <p><strong>Saturday:</strong> 9.00 AM - 1.00 PM</p>
            <p><strong>Sunday:</strong> Closed</p>
            <div class="panel-divider"></div>
            <p><strong>Need help?</strong> Visit the main desk or email help@library.edu</p>
        </div>
    </div>
</section>

<section class="home-info">
    <div class="container info-grid">
        <div class="info-card">
            <h3>Quick Search</h3>
            <p>Find books by title, author, or category once you log in.</p>
        </div>
        <div class="info-card">
            <h3>Borrow & Return</h3>
            <p>Track borrowing history, due dates, and return status online.</p>
        </div>
        <div class="info-card">
            <h3>Membership</h3>
            <p>Student, lecturer, and staff memberships are available.</p>
        </div>
    </div>
</section>

<footer class="main-footer">
    <p>&copy; 2026 SLIIT Library Management System</p>
</footer>

</body>
</html>